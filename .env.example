# Mapbox API Token
# Get your token from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# API Base URL (defaults to same origin)
# For local development, you can leave this empty.
# For production builds (GitHub Pages has no /api backend), set it to the
# Cloudflare Worker domain so view/like counts work:
# VITE_API_BASE_URL=https://yuq.smallworldai.com
